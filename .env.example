# Pick at least one provider key (others can stay empty).
CEREBRAS_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Provider selection (optional — first available from order is used)
LLM_PROVIDER=
LLM_MODEL=

# Retry / backoff for LLM calls
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_SECONDS=1.0

# Rate limiting on /api/chat, /api/scan, /api/upload-cv
ENABLE_RATE_LIMIT=1

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Server
PORT=8000

# Override DB path (defaults to data/searcher.db inside the workspace)
SEARCHER_DB_PATH=
